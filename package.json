{
  "name": "ospinajuanp-macroboard",
  "version": "1.0.0",
  "private": true,
  "description": "Controlador Virtual de Macros y Escenas para Streamers",
  "author": "Juan Pablo Ospina Restrepo",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm -r --parallel --stream dev",
    "build": "pnpm -r build",
    "build:server": "pnpm --filter @ospinajuanp-macroboard/server build",
    "build:admin": "pnpm --filter @ospinajuanp-macroboard/admin build",
    "build:client": "pnpm --filter @ospinajuanp-macroboard/client build",
    "clean": "pnpm -r exec rimraf .next dist out",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "package": "pnpm --filter @ospinajuanp-macroboard/server package"
  },
  "devDependencies": {
    "@tsconfig/node18": "^1.0.0",
    "@types/node": "^20.11.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
