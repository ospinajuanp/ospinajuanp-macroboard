{
  "name": "@ospinajuanp-macroboard/server",
  "version": "1.0.0",
  "private": true,
  "license": "PolyForm-Noncommercial-1.0.0",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsc && node dist/index.js",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepackage": "node scripts/prepare-package.js",
    "package": "pkg dist/index.js --targets node18-win-x64 --output dist/ospinajuanp-macroboard.exe",
    "prepare-installer": "node -e \"const fs=require('fs');const path='installer';if(!fs.existsSync(path)){fs.mkdirSync(path,{recursive:true});console.log('Created installer directory');}\""
  },
  "dependencies": {
    "@ospinajuanp-macroboard/shared": "workspace:*",
    "dotenv": "^16.3.1",
    "fastify": "^4.25.2",
    "fastify-plugin": "^4.5.1",
    "obs-websocket-js": "^5.0.0",
    "qrcode": "^1.5.3",
    "ws": "^8.16.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/qrcode": "^1.5.5",
    "@types/ws": "^8.5.10",
    "pkg": "^5.8.1",
    "typescript": "^5.3.3"
  }
}
